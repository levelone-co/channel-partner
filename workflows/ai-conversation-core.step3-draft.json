      "id": "35f22c15-0fa5-4cb9-a3e8-aa9069d6c775",
      "name": "Search Wines",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1328,
        0
      ],
      "alwaysOutputData": true,
      "executeOnce": true
