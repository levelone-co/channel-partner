# Copy to .env and fill. .env is gitignored.

# --- Supabase ---
# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...   # service_role, NOT anon — bypasses RLS
SUPABASE_ANON_KEY=eyJhbGciOiJI...           # optional, for read-only clients

# --- Voyage AI ---
# https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-...

# --- Shopify Admin API ---
# Apps → Develop apps → Create app → Configure Admin API scopes (read_products
# minimum; add write_draft_orders + read_inventory before Step 4).
SHOPIFY_STORE_DOMAIN=level-24-co.myshopify.com

# Either supply a static admin token directly...
# SHOPIFY_ADMIN_TOKEN=shpat_...

# ...or supply client credentials and the ingest script will mint a token
# on each run via the client_credentials grant. Get these from the Custom
# App's "API credentials" tab (Client ID + Client secret).
# https://shopify.dev/docs/apps/build/authentication-authorization/client-secrets
SHOPIFY_CLIENT_ID=...
SHOPIFY_CLIENT_SECRET=shpss_or_shpca_...

# Storefront API access token (Custom App → API credentials → Storefront API)
# Used by the Step 4 cart tools (check_stock / add_to_cart) via the
# X-Shopify-Storefront-Access-Token header. Used only by n8n, not scripts.
# Set as an n8n Variable named SHOPIFY_STOREFRONT_TOKEN.
# SHOPIFY_STOREFRONT_TOKEN=shpss_...

# --- Anthropic (used only by n8n; not by scripts) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- GoHighLevel (used only by n8n; not by scripts) ---
# GHL sub-account → Settings → Private Integrations → Create Integration.
# Scopes: contacts.readonly, contacts.write, conversations.readonly,
# conversations.write, conversations/message.write, locations.readonly.
# GHL_API_TOKEN=pit-...
# GHL_LOCATION_ID=...   # from app.gohighlevel.com/v2/location/<id>/...

# --- Tavily (consult_web tool, used by n8n) ---
# https://app.tavily.com → API Keys (free tier 1000 searches/month)
# TAVILY_API_KEY=tvly-...

# --- Slack (consult_team tool, used by n8n) ---
# Per-tenant Slack incoming webhook URL — store the URL in the `tenants.slack_webhook_url`
# column rather than .env so multi-tenant routing works. .env only used for local testing.
# SLACK_WEBHOOK_URL_LEVEL_24=https://hooks.slack.com/services/...

# --- Tenant ---
# The slug used for the default operation. Scripts can override via --tenant.
DEFAULT_TENANT_SLUG=level_24_wines
