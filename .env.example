# Copy to .env and fill. .env is gitignored.

# --- Supabase ---
# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...   # service_role, NOT anon — bypasses RLS
SUPABASE_ANON_KEY=eyJhbGciOiJI...           # optional, for read-only clients

# --- Voyage AI ---
# https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=pa-...

# --- Shopify Admin API ---
# Apps → Develop apps → Create app → Admin API access token
# Required scopes: read_products (Step 2), write_draft_orders (Step 4)
SHOPIFY_STORE_DOMAIN=level-24-wines.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_...

# --- Anthropic (used only by n8n; not by scripts) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Tenant ---
# The slug used for the default operation. Scripts can override via --tenant.
DEFAULT_TENANT_SLUG=level_24_wines
